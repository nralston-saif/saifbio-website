# Donate form → internal backend ingestion.
# The /donate form posts to /api/donation-inquiry (same origin), which forwards
# the submission server-to-server to the SAIFbio internal ops backend.
#
# BIO_INQUIRY_INGEST_URL  — full URL of the backend's public ingestion endpoint,
#                           e.g. https://internal.saif.vc/bio/api/public/donation-inquiry
# DONATION_INQUIRY_INGEST_SECRET — shared secret sent as the `x-inquiry-secret`
#                           header; must match the same var in the saif-bio
#                           backend. Generate: openssl rand -hex 32
#
# If either is unset, the form returns a friendly "email us instead" message.
BIO_INQUIRY_INGEST_URL=https://internal.saif.vc/bio/api/public/donation-inquiry
DONATION_INQUIRY_INGEST_SECRET=your-inquiry-ingest-secret
